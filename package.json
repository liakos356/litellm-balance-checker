{
  "name": "corellm",
  "displayName": "CoreLLM",
  "description": "Monitor LiteLLM API key balances, budgets, and usage directly from VS Code status bar",
  "version": "0.6.0",
  "publisher": "litellm-tools",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/core-innovation/litellm-balance-checker.git"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "corellm.refresh",
        "title": "CoreLLM: Refresh Balance"
      },
      {
        "command": "corellm.openSettings",
        "title": "CoreLLM: Open Settings"
      },
      {
        "command": "corellm.toggleAutoRefresh",
        "title": "CoreLLM: Toggle Auto-Refresh"
      },
      {
        "command": "corellm.enableAutoRefresh",
        "title": "CoreLLM: Enable Auto-Refresh"
      },
      {
        "command": "corellm.disableAutoRefresh",
        "title": "CoreLLM: Disable Auto-Refresh"
      },
      {
        "command": "corellm.showBudgetOverview",
        "title": "CoreLLM: Show Budget Overview"
      },
      {
        "command": "corellm.showSpendLogs",
        "title": "CoreLLM: Show Spend Logs"
      },
      {
        "command": "corellm.listKeys",
        "title": "CoreLLM: List All Keys"
      },
      {
        "command": "corellm.setReportDuration",
        "title": "CoreLLM: Set Report Duration"
      },
      {
        "command": "corellm.checkForUpdates",
        "title": "CoreLLM: Check for Updates"
      },
      {
        "command": "corellm.showAbout",
        "title": "CoreLLM: About"
      },
      {
        "command": "corellm.showTutorial",
        "title": "CoreLLM: Show Tutorial"
      },
      {
        "command": "corellm.showChangelog",
        "title": "CoreLLM: Show Changelog"
      },
      {
        "command": "corellm.showGlobalSpend",
        "title": "CoreLLM: Show Global Spend"
      },
      {
        "command": "corellm.showTeams",
        "title": "CoreLLM: Show Teams"
      },
      {
        "command": "corellm.showActivity",
        "title": "CoreLLM: Show Activity"
      },
      {
        "command": "corellm.showModelInfo",
        "title": "CoreLLM: Show Model Info"
      },
      {
        "command": "corellm.showSpendByTags",
        "title": "CoreLLM: Show Spend by Tags"
      },
      {
        "command": "corellm.showKeyHealth",
        "title": "CoreLLM: Show Key Health"
      },
      {
        "command": "corellm.cycleDisplay",
        "title": "CoreLLM: Cycle Status Bar Display"
      }
    ],
    "configuration": {
      "title": "CoreLLM",
      "properties": {
        "corellm.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your LiteLLM API key to check balance for. If empty, the Authorization header will use the key being queried."
        },
        "corellm.adminKey": {
          "type": "string",
          "default": "",
          "description": "Admin/proxy master key (if required) for querying key info. Leave empty if using the same key as apiKey."
        },
        "corellm.username": {
          "type": "string",
          "default": "",
          "description": "LiteLLM UI username (for login-based auth, used together with password). The extension will login and extract the embedded API key from the session."
        },
        "corellm.password": {
          "type": "string",
          "default": "",
          "editPresentation": "password",
          "description": "LiteLLM UI password (for login-based auth)."
        },
        "corellm.endpoint": {
          "type": "string",
          "default": "http://core.llm",
          "description": "The LiteLLM proxy endpoint URL (e.g., http://localhost:4000 or http://core.llm)"
        },
        "corellm.refreshInterval": {
          "type": "number",
          "default": 60,
          "minimum": 5,
          "description": "Auto-refresh interval in seconds (minimum 5). Set to 0 to disable auto-refresh."
        },
        "corellm.showKeyAlias": {
          "type": "boolean",
          "default": true,
          "description": "Show the key alias/name in the status bar next to the balance"
        },
        "corellm.showSpendLogs": {
          "type": "boolean",
          "default": false,
          "description": "Also display recent spend in the status bar (uses /spend/logs)"
        },
        "corellm.budgetWarningThreshold": {
          "type": "number",
          "default": 20,
          "minimum": 0,
          "maximum": 100,
          "description": "Warning threshold percentage. When remaining budget falls below this % of max_budget, show a warning."
        },
        "corellm.keyToQuery": {
          "type": "string",
          "default": "",
          "description": "Optional: Query a specific key (different from the auth key). If empty, queries the key used for authentication."
        },
        "corellm.reportDuration": {
          "type": "string",
          "default": "7d",
          "enum": [
            "1h",
            "24h",
            "7d",
            "30d",
            "custom"
          ],
          "enumDescriptions": [
            "Last hour",
            "Last 24 hours",
            "Last 7 days",
            "Last 30 days",
            "Custom range (set dates below)"
          ],
          "description": "Time range for the Budget Overview spend report."
        },
        "corellm.reportCustomStart": {
          "type": "string",
          "default": "",
          "description": "Custom start date (YYYY-MM-DD) for the spend report when reportDuration=custom."
        },
        "corellm.reportCustomEnd": {
          "type": "string",
          "default": "",
          "description": "Custom end date (YYYY-MM-DD) for the spend report when reportDuration=custom."
        },
        "corellm.updateCheckInterval": {
          "type": "number",
          "default": 24,
          "minimum": 1,
          "description": "How often (in hours) to check for updates on GitHub. Checks once on startup regardless."
        },
        "corellm.webviewTheme": {
          "type": "string",
          "default": "vscode",
          "enum": [
            "vscode",
            "light",
            "dark",
            "hc"
          ],
          "enumDescriptions": [
            "Follow VS Code theme",
            "Light theme override",
            "Dark theme override",
            "High-contrast theme override"
          ],
          "description": "Theme override for CoreLLM webview panels. Choose 'vscode' to follow your VS Code theme."
        },
        "corellm.showTeamSpend": {
          "type": "boolean",
          "default": false,
          "description": "Show team-level spend breakdown in the status bar"
        },
        "corellm.showGlobalSpend": {
          "type": "boolean",
          "default": false,
          "description": "Show global spend totals in the status bar"
        },
        "corellm.showModelSpend": {
          "type": "boolean",
          "default": false,
          "description": "Show per-model spend breakdown in panel views"
        },
        "corellm.cacheResults": {
          "type": "boolean",
          "default": true,
          "description": "Cache API results to reduce network requests (cache refreshes on each poll)"
        },
        "corellm.spendAlertThreshold": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Alert threshold in USD. Show a notification when any single spend entry exceeds this amount. Set to 0 to disable."
        },
        "corellm.enableActivityMonitoring": {
          "type": "boolean",
          "default": false,
          "description": "Enable proxy activity monitoring (additional API calls to /global/activity endpoints)"
        },
        "corellm.teamFilter": {
          "type": "string",
          "default": "",
          "description": "Optional: Filter by specific team ID. When set, only data for this team is shown."
        },
        "corellm.defaultPanelTab": {
          "type": "string",
          "default": "overview",
          "enum": [
            "overview",
            "global",
            "teams",
            "activity"
          ],
          "enumDescriptions": [
            "Budget Overview (default)",
            "Global Spend",
            "Teams",
            "Activity"
          ],
          "description": "Default tab to show when opening panels"
        },
        "corellm.statusBarDisplayMode": {
          "type": "string",
          "default": "cycle",
          "enum": [
            "cycle",
            "remaining",
            "spend",
            "usage-bar",
            "budget"
          ],
          "enumDescriptions": [
            "Cycle through all modes on click",
            "Show remaining budget",
            "Show total spend",
            "Show usage percentage with ASCII bar",
            "Show max budget"
          ],
          "description": "Default status bar display mode"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "test": "npm run compile && npm run lint"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  }
}

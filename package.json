{
  "name": "corellm",
  "displayName": "CoreLLM",
  "description": "Monitor LiteLLM proxy balances, budgets, and usage — status bar spend tracking, rich dashboards, key health, team budgets, model pricing, CSV/PDF export",
  "version": "0.8.11",
  "publisher": "CoreInnovation",
  "icon": "docs/logo.png",
  "license": "MIT",
  "homepage": "https://github.com/core-innovation/litellm-balance-checker#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/core-innovation/litellm-balance-checker.git"
  },
  "bugs": {
    "url": "https://github.com/core-innovation/litellm-balance-checker/issues"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "categories": [
    "Data Science",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "litellm",
    "llm",
    "api",
    "balance",
    "budget",
    "spend",
    "monitoring",
    "dashboard",
    "openai",
    "anthropic",
    "proxy",
    "keys",
    "teams",
    "cost-tracking"
  ],
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/badge/license-MIT-green",
      "href": "https://github.com/core-innovation/litellm-balance-checker/blob/main/LICENSE",
      "description": "MIT License"
    },
    {
      "url": "https://img.shields.io/badge/vscode-%5E1.85.0-blue?logo=visualstudiocode",
      "href": "https://code.visualstudio.com/",
      "description": "VS Code ^1.85.0"
    }
  ],
  "pricing": "Free",
  "qna": "https://github.com/core-innovation/litellm-balance-checker/discussions",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "corellm": [
        {
          "id": "corellm.treeView",
          "name": "CoreLLM Monitor"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "corellm",
          "title": "CoreLLM",
          "icon": "$(graph)"
        }
      ]
    },
    "commands": [
      {
        "command": "corellm.refresh",
        "title": "CoreLLM: Refresh Balance"
      },
      {
        "command": "corellm.openSettings",
        "title": "CoreLLM: Open Settings"
      },
      {
        "command": "corellm.toggleAutoRefresh",
        "title": "CoreLLM: Toggle Auto-Refresh"
      },
      {
        "command": "corellm.enableAutoRefresh",
        "title": "CoreLLM: Enable Auto-Refresh"
      },
      {
        "command": "corellm.disableAutoRefresh",
        "title": "CoreLLM: Disable Auto-Refresh"
      },
      {
        "command": "corellm.showBudgetOverview",
        "title": "CoreLLM: Show Budget Overview"
      },
      {
        "command": "corellm.showSpendLogs",
        "title": "CoreLLM: Show Spend Logs"
      },
      {
        "command": "corellm.listKeys",
        "title": "CoreLLM: List All Keys"
      },
      {
        "command": "corellm.setReportDuration",
        "title": "CoreLLM: Set Report Duration"
      },
      {
        "command": "corellm.showAbout",
        "title": "CoreLLM: About"
      },
      {
        "command": "corellm.showTutorial",
        "title": "CoreLLM: Show Tutorial"
      },
      {
        "command": "corellm.showChangelog",
        "title": "CoreLLM: Show Changelog"
      },
      {
        "command": "corellm.showGlobalSpend",
        "title": "CoreLLM: Show Global Spend"
      },
      {
        "command": "corellm.showTeams",
        "title": "CoreLLM: Show Teams"
      },
      {
        "command": "corellm.showActivity",
        "title": "CoreLLM: Show Activity"
      },
      {
        "command": "corellm.showModelInfo",
        "title": "CoreLLM: Show Model Info"
      },
      {
        "command": "corellm.showSpendByTags",
        "title": "CoreLLM: Show Spend by Tags"
      },
      {
        "command": "corellm.showKeyHealth",
        "title": "CoreLLM: Show Key Health"
      },
      {
        "command": "corellm.cycleDisplay",
        "title": "CoreLLM: Cycle Status Bar Display"
      },
      {
        "command": "corellm.showHealthDashboard",
        "title": "CoreLLM: Show Health Dashboard"
      },
      {
        "command": "corellm.showProviderSpend",
        "title": "CoreLLM: Show Provider Spend"
      },
      {
        "command": "corellm.showUserManager",
        "title": "CoreLLM: Show User Manager"
      },
      {
        "command": "corellm.showUnifiedDashboard",
        "title": "CoreLLM: Show Dashboard"
      },
      {
        "command": "corellm.showWelcome",
        "title": "CoreLLM: Show Welcome Screen"
      },
      {
        "command": "corellm.showRequestLogs",
        "title": "CoreLLM: Show Request Logs"
      },
      {
        "command": "corellm.setApiKey",
        "title": "CoreLLM: Set API Key (Secure)"
      },
      {
        "command": "corellm.setAdminKey",
        "title": "CoreLLM: Set Admin Key (Secure)"
      },
      {
        "command": "corellm.setPassword",
        "title": "CoreLLM: Set Password (Secure)"
      },
      {
        "command": "corellm.clearCredentials",
        "title": "CoreLLM: Clear All Stored Credentials"
      }
    ],
    "configuration": {
      "title": "CoreLLM",
      "properties": {
        "corellm.apiKey": {
          "type": "string",
          "default": "",
          "editPresentation": "password",
          "description": "Your LiteLLM API key to check balance for. If empty, the Authorization header will use the key being queried."
        },
        "corellm.adminKey": {
          "type": "string",
          "default": "",
          "editPresentation": "password",
          "description": "Admin/proxy master key (if required) for querying key info. Leave empty if using the same key as apiKey."
        },
        "corellm.username": {
          "type": "string",
          "default": "",
          "description": "LiteLLM UI username (for login-based auth, used together with password). The extension will login and extract the embedded API key from the session."
        },
        "corellm.password": {
          "type": "string",
          "default": "",
          "editPresentation": "password",
          "description": "LiteLLM UI password (for login-based auth)."
        },
        "corellm.endpoint": {
          "type": "string",
          "default": "http://localhost:4000",
          "description": "The LiteLLM proxy endpoint URL (e.g., http://localhost:4000)"
        },
        "corellm.refreshInterval": {
          "type": "number",
          "default": 60,
          "minimum": 5,
          "description": "Auto-refresh interval in seconds (minimum 5). Set to 0 to disable auto-refresh."
        },
        "corellm.showKeyAlias": {
          "type": "boolean",
          "default": true,
          "description": "Show the key alias/name in the status bar next to the balance"
        },
        "corellm.showSpendLogs": {
          "type": "boolean",
          "default": false,
          "description": "Also display recent spend in the status bar (uses /spend/logs)"
        },
        "corellm.budgetWarningThreshold": {
          "type": "number",
          "default": 20,
          "minimum": 0,
          "maximum": 100,
          "description": "Warning threshold percentage. When remaining budget falls below this % of max_budget, show a warning."
        },
        "corellm.keyToQuery": {
          "type": "string",
          "default": "",
          "description": "Optional: Query a specific key (different from the auth key). If empty, queries the key used for authentication."
        },
        "corellm.reportDuration": {
          "type": "string",
          "default": "7d",
          "enum": [
            "1h",
            "24h",
            "7d",
            "30d",
            "custom"
          ],
          "enumDescriptions": [
            "Last hour",
            "Last 24 hours",
            "Last 7 days",
            "Last 30 days",
            "Custom range (set dates below)"
          ],
          "description": "Time range for the Budget Overview spend report."
        },
        "corellm.reportCustomStart": {
          "type": "string",
          "default": "",
          "description": "Custom start date (YYYY-MM-DD) for the spend report when reportDuration=custom."
        },
        "corellm.reportCustomEnd": {
          "type": "string",
          "default": "",
          "description": "Custom end date (YYYY-MM-DD) for the spend report when reportDuration=custom."
        },
        "corellm.webviewTheme": {
          "type": "string",
          "default": "vscode",
          "enum": [
            "vscode",
            "light",
            "dark",
            "hc"
          ],
          "enumDescriptions": [
            "Follow VS Code theme",
            "Light theme override",
            "Dark theme override",
            "High-contrast theme override"
          ],
          "description": "Theme override for CoreLLM webview panels. Choose 'vscode' to follow your VS Code theme."
        },
        "corellm.showTeamSpend": {
          "type": "boolean",
          "default": false,
          "description": "Show team-level spend breakdown in the status bar"
        },
        "corellm.showGlobalSpend": {
          "type": "boolean",
          "default": false,
          "description": "Show global spend totals in the status bar"
        },
        "corellm.showModelSpend": {
          "type": "boolean",
          "default": false,
          "description": "Show per-model spend breakdown in panel views"
        },
        "corellm.cacheResults": {
          "type": "boolean",
          "default": true,
          "description": "Cache API results to reduce network requests (cache refreshes on each poll)"
        },
        "corellm.spendAlertThreshold": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Alert threshold in USD. Show a notification when any single spend entry exceeds this amount. Set to 0 to disable."
        },
        "corellm.enableActivityMonitoring": {
          "type": "boolean",
          "default": false,
          "description": "Enable proxy activity monitoring (additional API calls to /global/activity endpoints)"
        },
        "corellm.teamFilter": {
          "type": "string",
          "default": "",
          "description": "Optional: Filter by specific team ID. When set, only data for this team is shown."
        },
        "corellm.defaultPanelTab": {
          "type": "string",
          "default": "overview",
          "enum": [
            "overview",
            "global",
            "teams",
            "activity"
          ],
          "enumDescriptions": [
            "Budget Overview (default)",
            "Global Spend",
            "Teams",
            "Activity"
          ],
          "description": "Default tab to show when opening panels"
        },
        "corellm.statusBarDisplayMode": {
          "type": "string",
          "default": "cycle",
          "enum": [
            "cycle",
            "remaining",
            "spend",
            "usage-bar",
            "budget"
          ],
          "enumDescriptions": [
            "Cycle through all modes on click",
            "Show remaining budget",
            "Show total spend",
            "Show usage percentage with ASCII bar",
            "Show max budget"
          ],
          "description": "Default status bar display mode"
        },
        "corellm.healthCheckInterval": {
          "type": "number",
          "default": 300,
          "minimum": 30,
          "description": "Health check polling interval in seconds (minimum 30). Used for the Health Dashboard."
        },
        "corellm.enableHealthMonitoring": {
          "type": "boolean",
          "default": false,
          "description": "Enable continuous proxy health monitoring. Shows alerts when endpoints go unhealthy."
        },
        "corellm.healthAlertOnUnhealthy": {
          "type": "boolean",
          "default": true,
          "description": "Show a VS Code notification when any model endpoint becomes unhealthy."
        },
        "corellm.enableSpendForecast": {
          "type": "boolean",
          "default": true,
          "description": "Show projected 30-day spend forecast in the Dashboard based on recent usage patterns."
        },
        "corellm.forecastDays": {
          "type": "number",
          "default": 7,
          "minimum": 1,
          "maximum": 90,
          "description": "Number of recent days to use for spend forecasting."
        },
        "corellm.enableBudgetAlerts": {
          "type": "boolean",
          "default": true,
          "description": "Show VS Code notifications when budget thresholds are crossed."
        },
        "corellm.budgetAlertThreshold": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "maximum": 100,
          "description": "Budget usage percentage threshold for alerts."
        },
        "corellm.enableDailySpendAlert": {
          "type": "boolean",
          "default": false,
          "description": "Alert when daily spend exceeds a configured threshold."
        },
        "corellm.dailySpendAlertThreshold": {
          "type": "number",
          "default": 10,
          "minimum": 0,
          "description": "Daily spend threshold in USD. Alert when daily spend exceeds this amount."
        },
        "corellm.enableProviderBreakdown": {
          "type": "boolean",
          "default": true,
          "description": "Show per-provider spend breakdowns (OpenAI, Anthropic, etc.) in panels."
        },
        "corellm.compactStatusBar": {
          "type": "boolean",
          "default": false,
          "description": "Use a compact status bar display showing only the spend amount."
        },
        "corellm.dateFormat": {
          "type": "string",
          "default": "relative",
          "enum": [
            "relative",
            "absolute",
            "iso"
          ],
          "enumDescriptions": [
            "Relative time (e.g., 2m ago, 3h ago)",
            "Absolute date/time",
            "ISO 8601 format"
          ],
          "description": "Date/time display format in webview panels."
        },
        "corellm.enableTreeView": {
          "type": "boolean",
          "default": true,
          "description": "Show CoreLLM in the VS Code sidebar as a tree view for quick access."
        },
        "corellm.treeViewAutoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Auto-refresh the sidebar tree view data."
        },
        "corellm.enableRequestLogging": {
          "type": "boolean",
          "default": false,
          "description": "Log raw HTTP request/response text for debugging. View them via the 'CoreLLM: Show Request Logs' command."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "test": "npm run compile && npm run lint"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  }
}
